# ============================================================
# Sports Analytics Intelligence Platform — Environment Config
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://analyst:analytics2026@localhost:5432/sports_analytics

# ── Gemini LLM (Powers Chatbot + Intelligence Layer) ─────────
# Get your key from: https://aistudio.google.com/app/apikey
# To switch to a different LLM (e.g. Minimax), only update LLMClient
# in backend/src/intelligence/chat_service.py — nothing else needs to change.
GEMINI_API_KEY=your_gemini_api_key_here

# ── Chatbot Engine (Phase 7A) ────────────────────────────────
# legacy   = existing custom orchestration (default)
# langgraph= LangGraph orchestration with LangChain node wrappers
CHAT_ENGINE=legacy

# ── Intelligence / RAG ────────────────────────────────────────
INTELLIGENCE_ENABLED=true
RAG_TOP_K=6
RAG_MAX_AGE_HOURS=120
RAG_SUMMARY_MODEL=gemini-2.0-flash
RAG_EMBEDDING_MODEL=models/embedding-001
RAG_REQUEST_TIMEOUT_SECONDS=8

# ── Season ───────────────────────────────────────────────────
CURRENT_SEASON=2025-26

# ── MLOps ────────────────────────────────────────────────────
MLOPS_ACCURACY_THRESHOLD=0.55
MLOPS_MAX_BRIER=0.25
MLOPS_NEW_LABEL_MIN=40
MLOPS_FRESHNESS_DAYS=2

# ── Langfuse (Chatbot observability) ─────────────────────────
# Sign up for free at https://cloud.langfuse.com to get your keys.
# When keys are absent the chatbot works normally; only tracing is skipped.
# Self-hosted Langfuse: change LANGFUSE_HOST to your server URL.
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_DEBUG=false

# ── Pipeline Scheduler ───────────────────────────────────────
# Seasons to refresh on each daily run (comma-separated).
# Default: current season only — historical data doesn't change.
# For a one-off full backfill set: PIPELINE_SEASONS=2024-25,2025-26
PIPELINE_SEASONS=2025-26

# UTC hour/minute for the daily raw-ingestion + feature-engineering run.
# Default: 06:30 UTC = 12:00 PM IST (UTC+5:30).
# A feature-engineering safety-net fires 60 min later (07:30 UTC = 13:00 IST).
PIPELINE_SCHEDULE_HOUR=6
PIPELINE_SCHEDULE_MINUTE=30

# UTC hours at which RAG vector-store is refreshed (comma-separated integers).
# Default: every 6 hours — 00:00, 06:00, 12:00, 18:00 UTC
#          = 05:30, 11:30, 17:30, 23:30 IST.
# The 06:00 UTC slot fires 30 min before ingestion so news context is fresh.
RAG_SCHEDULE_HOURS=0,6,12,18
